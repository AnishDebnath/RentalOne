{
  "compilerOptions": {
    "target": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@camera-rental-house/shared": ["packages/shared/index.ts"],
      "@camera-rental-house/shared/*": ["packages/shared/*"],
      "@camera-rental-house/database": ["server/src/db/supabase.ts"],
      "@camera-rental-house/cloud-storage/*": ["server/src/storage/*"],
      "@camera-rental-house/types": ["packages/types/index.ts"],
      "@camera-rental-house/ui": ["packages/ui/index.ts"],
      "@camera-rental-house/utils": ["packages/utils/index.ts"]
