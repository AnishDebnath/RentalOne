{
  "name": "rentalone",
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "npx concurrently \"npm run dev:client\" \"npm run dev:admin\" \"npm run dev:web\"",
    "dev:client": "npm --workspace apps/client run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "echo 'ERROR: Use npm run build:admin, npm run build:client, or npm run build:web to build a specific app for Vercel deployment' && exit 1",
    "build:all": "npm run build --workspaces --if-present",
    "build:client": "npm --workspace apps/client run build && node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true});f.cpSync('apps/client/dist','dist',{recursive:true})\"",
    "build:admin": "npm --workspace apps/admin run build && node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true});f.cpSync('apps/admin/dist','dist',{recursive:true})\"",
    "build:web": "npm --workspace apps/web run build",
    "build:server": "npm --workspace server run build",
    "start:server": "npm --workspace server run start"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
