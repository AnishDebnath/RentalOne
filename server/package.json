{
  "name": "@rentalone/server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:express --external:@supabase/supabase-js --external:jsonwebtoken --external:bcryptjs --external:cookie-parser --external:cors --external:multer --external:sharp --external:cloudinary --external:dotenv --external:qrcode --external:@aws-sdk/client-s3 --external:@aws-sdk/s3-request-presigner --external:helmet --external:compression --external:express-rate-limit --external:zod --outfile=dist/index.js",
    "prestart": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.782.0",
    "@aws-sdk/s3-request-presigner": "^3.782.0",
    "@rentalone/cloud-storage": "file:./src/storage",
    "@rentalone/database": "file:./src/db",
    "@rentalone/shared": "file:../packages/shared",
    "@supabase/supabase-js": "^2.49.4",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}